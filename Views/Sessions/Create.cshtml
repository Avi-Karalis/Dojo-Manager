@model Session
@{ ViewData["Title"] = "Create Session"; }
<h2>Create Session</h2>

<form asp-action="Create" method="post">
    <div>
        <label>Date</label>
        <input asp-for="Date" type="datetime-local" />
    </div>

    <div>
        <label>Location</label>
        <input asp-for="Location" />
    </div>

    <button type="submit">Save</button>
</form>