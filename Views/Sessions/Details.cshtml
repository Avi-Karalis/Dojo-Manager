@model Session
@{ ViewData["Title"] = "Session Details"; }
<h2>Session Details</h2>

<p>
    <strong>Date:</strong> @Model.Date <br />
    <strong>Location:</strong> @Model.Location
</p>

<h3>Attendees</h3>

@if (!Model.Attendances.Any())
{
    <p>No attendees yet.</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Name</th>
                <th>Rank</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var a in Model.Attendances)
            {
                <tr>
                    <td>@a.Student.Name</td>
                    <td>@RankHelper.Format(a.Student.Rank)</td>
                    <td>
                        <form asp-controller="Attendances" asp-action="Remove" method="post" style="display:inline">
                            <input type="hidden" name="studentId" value="@a.StudentId" />
                            <input type="hidden" name="sessionId" value="@a.SessionId" />
                            <button type="submit">Remove</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

<a asp-controller="Attendances"
   asp-action="Create"
   asp-route-sessionId="@Model.Id"
   class="btn btn-primary">
    Add Student to Session
</a>