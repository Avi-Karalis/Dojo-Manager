@model Session
@{ ViewData["Title"] = "Session Details"; }
<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Session Details</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">Back</a>
</div>

<div class="card p-4 mb-3" style="max-width:500px">
    <dl class="row mb-0">
        <dt class="col-sm-4">Date</dt>
        <dd class="col-sm-8">@Model.Date.ToString("yyyy-MM-dd, dddd")</dd>
        <dt class="col-sm-4">Location</dt>
        <dd class="col-sm-8">@Model.Location</dd>
    </dl>
</div>

<h3>Attendees</h3>

@if (!Model.Attendances.Any())
{
    <p>No attendees yet.</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Name</th>
                <th>Rank</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var a in Model.Attendances)
            {
                <tr>
                    <td>@a.Student.Name</td>
                    <td>@RankHelper.Format(a.Student.Rank)</td>
                    <td>
                        <form asp-controller="Attendances" asp-action="Remove" method="post" style="display:inline">
                            <input type="hidden" name="studentId" value="@a.StudentId" />
                            <input type="hidden" name="sessionId" value="@a.SessionId" />
                            <button type="submit" class="btn btn-sm btn-outline-danger">Remove</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

<a asp-controller="Attendances"
   asp-action="Create"
   asp-route-sessionId="@Model.Id"
   class="btn btn-primary">
    Add Student to Session
</a>