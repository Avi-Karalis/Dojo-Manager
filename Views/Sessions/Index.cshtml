@model List<Session>

<h2>Sessions</h2>

<a asp-action="Create">Create Session</a>

<ul>
    @foreach (var s in Model)
    {
        <li>
            @s.Date - @s.Location
            <a asp-action="Details" asp-route-id="@s.Id">View</a>
            <a asp-action="Delete" asp-route-id="@s.Id">Delete</a>
        </li>
    }
</ul>