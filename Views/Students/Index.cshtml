@model DojoManager.ViewModels.StudentIndexViewModel
@{
    ViewData["Title"] = "Students";
}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Students</h2>
    @if (User.Identity!.IsAuthenticated)
    {
        <a asp-action="Create" class="btn btn-primary">+ Create New</a>
    }
</div>

<table class="table">
    <thead>
        <tr>
            <th>
                <a href="@Url.Action("Index", new { page = 1, pageSize = Model.PageSize, sortBy = "name", sortDir = Model.NextDir("name") })" class="btn btn-sm btn-outline-secondary">
                    Name@(Model.SortIndicator("name"))
                </a>
            </th>
            <th>
                <a href="@Url.Action("Index", new { page = 1, pageSize = Model.PageSize, sortBy = "rank", sortDir = Model.NextDir("rank") })" class="btn btn-sm btn-outline-secondary">
                    Rank@(Model.SortIndicator("rank"))
                </a>
            </th>
            <th>
                <a href="@Url.Action("Index", new { page = 1, pageSize = Model.PageSize, sortBy = "isvisitor", sortDir = Model.NextDir("isvisitor") })" class="btn btn-sm btn-outline-secondary">
                    Type@(Model.SortIndicator("isvisitor"))
                </a>
            </th>
            @if (User.Identity!.IsAuthenticated)
            {
                <th>
                    <a href="@Url.Action("Index", new { page = 1, pageSize = Model.PageSize, sortBy = "lastpaiddate", sortDir = Model.NextDir("lastpaiddate") })" class="btn btn-sm btn-outline-secondary">
                        Payment@(Model.SortIndicator("lastpaiddate"))
                    </a>
                </th>
            }
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var s in Model.Students)
    {
        <tr>
            <td>@s.Name</td>
            <td>@RankHelper.Format(s.Rank)</td>
            <td>@(s.IsVisitor ? "Visitor" : "Member")</td>
            @if (User.Identity!.IsAuthenticated)
            {
                <td>
                    @if (s.IsVisitor)
                    {
                        <span class="text-muted">N/A</span>
                    }
                    else if (s.HasPaidThisMonth)
                    {
                        <span class="badge bg-success">✔ Paid</span>
                    }
                    else
                    {
                        <span class="badge bg-danger">✘ Not Paid</span>
                        <form asp-action="MarkAsPaid" method="post" style="display:inline">
                            <input type="hidden" name="id" value="@s.Id" />
                            <button type="submit" class="btn btn-sm btn-warning">Mark as Paid</button>
                        </form>
                    }
                </td>
            }
            <td>
                @if (User.Identity!.IsAuthenticated)
                {
                    <a asp-action="Edit" asp-route-id="@s.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                    <a asp-action="Delete" asp-route-id="@s.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                }
                <a asp-action="Details" asp-route-id="@s.Id" class="btn btn-sm btn-outline-secondary">Details</a>
            </td>
        </tr>
    }
    </tbody>
</table>

<div class="d-flex align-items-center gap-2 flex-wrap mt-2">
    @if (Model.HasPrev)
    {
        <a href="@Url.Action("Index", new { page = Model.Page - 1, pageSize = Model.PageSize, sortBy = Model.SortBy, sortDir = Model.SortDir })" class="btn btn-outline-secondary btn-sm">← Prev</a>
    }
    <span class="mx-1">Page @Model.Page of @Model.TotalPages (@Model.TotalCount total)</span>
    @if (Model.HasNext)
    {
        <a href="@Url.Action("Index", new { page = Model.Page + 1, pageSize = Model.PageSize, sortBy = Model.SortBy, sortDir = Model.SortDir })" class="btn btn-outline-secondary btn-sm">Next →</a>
    }
    <div class="ms-3 d-flex align-items-center gap-1">
        <span class="me-1">Per page:</span>
        @foreach (var size in new[] { 5, 10, 25, 50 })
        {
            <a href="@Url.Action("Index", new { page = 1, pageSize = size, sortBy = Model.SortBy, sortDir = Model.SortDir })"
               class="btn btn-sm @(Model.PageSize == size ? "btn-secondary" : "btn-outline-secondary")">@size</a>
        }
    </div>
</div>