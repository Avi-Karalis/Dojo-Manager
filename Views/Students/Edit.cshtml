@model Student
@{
    ViewData["Title"] = "Edit Student - " + Model.Name;
}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Edit Student</h2>
</div>

<div class="card p-4" style="max-width:500px">
    <form asp-action="Edit" method="post">
        <input type="hidden" asp-for="Id" />
        <div class="mb-3">
            <label class="form-label" asp-for="Name"></label>
            <input asp-for="Name" class="form-control" />
        </div>
        <div class="mb-3">
            <label class="form-label" asp-for="Rank"></label>
            <input asp-for="Rank" type="number" step="0.1" min="0" class="form-control" />
        </div>
        <div class="mb-3 form-check">
            <input asp-for="IsVisitor" type="checkbox" class="form-check-input" />
            <label class="form-check-label" asp-for="IsVisitor">Visitor (not eligible for monthly payment)</label>
        </div>
        <div id="paymentField" class="mb-3">
            <label class="form-label" asp-for="LastPaidDate">Last Paid Date</label>
            <input asp-for="LastPaidDate" type="date" class="form-control" />
        </div>
        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary">Save</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
        </div>
    </form>
</div>

<script>
    const visitorCheckbox = document.getElementById('IsVisitor');
    const paymentField = document.getElementById('paymentField');
    function togglePayment() {
        paymentField.style.display = visitorCheckbox.checked ? 'none' : 'block';
    }
    visitorCheckbox.addEventListener('change', togglePayment);
    togglePayment();
</script>
