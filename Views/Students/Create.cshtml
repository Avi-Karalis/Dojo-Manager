@model Student

<h2>Create Student</h2>

<form asp-action="Create" method="post">
    <div>
        <label>Name</label>
        <input asp-for="Name" />
    </div>

    <div>
        <label>Rank</label>
        <input asp-for="Rank" type="number" step="0.1" min="0" />
    </div>

    <button type="submit">Save</button>
</form>